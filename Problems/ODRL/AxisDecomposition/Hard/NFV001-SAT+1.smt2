(set-logic LRA)
(declare-const n0 Real)
(declare-const n5 Real)
(declare-const n10 Real)
(declare-const n15 Real)
(assert (< n0 n5))
(assert (< n5 n10))
(assert (< n10 n15))
; [n0,n5] and [n10,n15] are disjoint — witness n5 is in first but not second
(assert (<= n0 n5))
(assert (<= n5 n5))
(assert (not (and (>= n5 n10) (<= n5 n15))))
(check-sat)
(exit)
