# DPV Purpose slice v2 — benchmark-grade, trimmed
# https://github.com/w3c/dpv/blob/master/2.3/dpv/modules/purposes-owl.ttl
#
# 15 concepts, four-level hierarchy. Every rdfs:subClassOf / skos:broader
# edge verified against the authoritative DPV-OWL distribution
# (dpv-owl.ttl, v2.3, https://w3id.org/dpv/owl).
#
# Structure:
#   dpv:Purpose (top concept)
#   +-- 6 L2 categories: CommercialPurpose, NonCommercialPurpose,
#   |   ResearchAndDevelopment, Marketing, OrganisationGovernance,
#   |   Personalisation
#   +-- 7 L3 concepts:
#   |     AcademicResearch, CommercialResearch, NonCommercialResearch,
#   |     ScientificResearch            (under ResearchAndDevelopment,
#   |                                    two of them multi-parent)
#   |     Advertising, DirectMarketing, SocialMediaMarketing
#   |                                   (under Marketing)
#   +-- 1 L4 concept: PersonalisedAdvertising
#       (multi-parent: Advertising + Personalisation)
#
# Rationale:
#   - ScientificResearch has ResearchAndDevelopment as its only parent.
#     DPV does NOT assert ScientificResearch skos:broader NonCommercialPurpose.
#     This is the motivating-example Unknown case, grounded in real DPV.
#   - CommercialResearch and NonCommercialResearch have two parents each
#     (commercial/non-commercial category + ResearchAndDevelopment):
#     multi-parent at L3.
#   - PersonalisedAdvertising has two parents (Advertising + Personalisation):
#     multi-parent at L4. This exercises denotation intersection across
#     independent branches (Marketing vs Personalisation).
#   - OrganisationGovernance is retained as a childless L2 leaf for L2
#     sibling breadth in RQ2.
#
# Predicate shape follows DPV-SKOS: every concept is an instance of
# dpv:Purpose (the top concept) and skos:Concept, with skos:broader
# giving the immediate parent(s). No disjointness is asserted; DPV
# does not assert disjointness between sibling purposes, and the SDA
# profile is applied at evaluation time.
# ScientificResearch has no link to NonCommercialPurpose. DPV asserts only rdfs:subClassOf dpv-owl:ResearchAndDevelopment. Motivating-example \Unknown{} holds.
# Marketing has no link to CommercialPurpose. DPV asserts rdfs:subClassOf dpv-owl:Purpose directly. Marketing is a top-level sibling, not a child.
# AcademicResearch has no link to NonCommercialPurpose. DPV asserts only rdfs:subClassOf dpv-owl:ResearchAndDevelopment. Clean for RQ2 sibling cases.

@prefix dpv:  <https://w3id.org/dpv#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

### Top concept #############################################################

dpv:Purpose a rdfs:Class, skos:Concept ;
    skos:prefLabel "Purpose" .

### L2: top-level categories ################################################

dpv:CommercialPurpose a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Commercial Purpose" ;
    skos:broader dpv:Purpose .

dpv:NonCommercialPurpose a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Non-commercial Purpose" ;
    skos:broader dpv:Purpose .

dpv:ResearchAndDevelopment a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Research and Development" ;
    skos:broader dpv:Purpose .

dpv:Marketing a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Marketing" ;
    skos:broader dpv:Purpose .

dpv:OrganisationGovernance a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Organisation Governance" ;
    skos:broader dpv:Purpose .

dpv:Personalisation a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Personalisation" ;
    skos:broader dpv:Purpose .

### L3: Research subtree ####################################################

dpv:AcademicResearch a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Academic Research" ;
    skos:broader dpv:ResearchAndDevelopment .

dpv:CommercialResearch a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Commercial Research" ;
    skos:broader dpv:CommercialPurpose, dpv:ResearchAndDevelopment .

dpv:NonCommercialResearch a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Non-commercial Research" ;
    skos:broader dpv:NonCommercialPurpose, dpv:ResearchAndDevelopment .

dpv:ScientificResearch a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Scientific Research" ;
    skos:broader dpv:ResearchAndDevelopment .

### L3: Marketing subtree ###################################################

dpv:Advertising a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Advertising" ;
    skos:broader dpv:Marketing .

dpv:DirectMarketing a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Direct Marketing" ;
    skos:broader dpv:Marketing .

dpv:SocialMediaMarketing a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Social Media Marketing" ;
    skos:broader dpv:Marketing .

### L4: cross-branch multi-parent ###########################################

dpv:PersonalisedAdvertising a dpv:Purpose, skos:Concept ;
    skos:prefLabel "Personalised Advertising" ;
    skos:broader dpv:Advertising, dpv:Personalisation .