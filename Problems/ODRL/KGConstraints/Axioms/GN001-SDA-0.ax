%--------------------------------------------------------------------------
% File     : GN001-SDA-0.ax
% Domain   : ODRL Policy / KB Grounding Concept-valued
% Axioms   : GeoNames Sibling Disjointness Assumption (SDA) profile
% Version  : 1.0
% English  : Sibling disjointness profile for GeoNames. Augments GN000-0.ax
%           : with pairwise kge_disjoint facts for siblings sharing both a
%           : parent and a featureCode. Cross-featureCode 'siblings'
%           : (e.g., city vs region under the same country) are NOT made
%           : disjoint, because they're nested. GeoNames as published does
%           : not assert sibling disjointness; this profile is required for
%           : spatial Conflict verdicts.
%
% Refs     : [Mus+26b] Mustafa, D., Collarana, D., Lange, C., Peng, Y., Haque, R., Quix, C., Decker, S. Denotational Semantics for ODRL: Knowledge-Based Constraint Conflict Detection. 2026. arXiv:2602.19883. https://arxiv.org/abs/2602.19883
% Source   : Mustafa, D. (2026)
% Authors  : Mustafa, D. & Sutcliffe, G.
% Names    : GN001-SDA-0.ax
%
% Status   : Satisfiable
% SPC      : FOF_SAT_RFN
%
% Comments : Generated from Resources/geonames.ttl by gen_geonames_sda.py.
%           : Depends on KGE000-0.ax (kge_disjoint signature, kge_disjoint_symmetric,
%           : kge_disjoint_irreflexive, kge_disjoint_propagation) and GN000-0.ax
%           : (parent edges; transitive closure via kge_leq_transitive).
%           : Problems requiring spatial Conflict verdicts emit, in order:
%           : include('Axioms/KGE000-0.ax').
%           : include('Axioms/DENOT000-0.ax').
%           : include('Axioms/GN000-0.ax').
%           : include('Axioms/GN001-SDA-0.ax').    -- adds sibling disjointness
%           : Problems testing spatial Unknown verdicts MUST NOT include this
%           : file -- their Unknown verdict depends on absence of disjointness.
%           : No axiom file self-includes this file.
%           : 19 axioms: 19 pairwise disjointness facts across 3 sibling groups.
%--------------------------------------------------------------------------

% ==========================================================================
% GeoNames Sibling Disjointness Assumption (SDA) profile
%                                          [Paper: tab:realizations]
%
% Source: Resources/geonames.ttl (same as GN000-0.ax)
% Encoding: for each (parent, featureCode) group with at least two
% children, emit pairwise kge_disjoint facts among the children.
%
% Rationale: GeoNames as published does not assert that siblings
% are mutually exclusive. For static conflict detection on the
% spatial operand, we adopt the closed-world convention that two
% same-kind administrative or political units sharing a parent
% (e.g., two A.PCLI countries under Europe; two A.ADM1 regions
% under France) name disjoint sets of places. This is sound for
% standard administrative hierarchies; cross-featureCode pairs
% (city vs region) are nested, not disjoint, and are NOT made
% disjoint here.
%
% Use: problems that need spatial Conflict verdicts include this
% file IN ADDITION TO GN000-0.ax. Problems testing spatial Unknown
% verdicts do NOT include this file -- their Unknown verdict
% depends on the absence of asserted disjointness.
%
% Sibling groups with at least two members: 3.
% Pairwise disjointness facts emitted: 19.
% Source features (from GN000-0.ax): 15.
% ==========================================================================
% ----- Siblings under gn_europe (featureCode A.PCLI) -----
fof(sda_france_disjoint_germany, axiom, kge_disjoint(gn_france, gn_germany)).

% ----- Siblings under gn_france (featureCode A.ADM1) -----
fof(sda_auvergne_rhone_alpes_disjoint_grand_est, axiom, kge_disjoint(gn_auvergne_rhone_alpes, gn_grand_est)).
fof(sda_auvergne_rhone_alpes_disjoint_ile_de_france, axiom, kge_disjoint(gn_auvergne_rhone_alpes, gn_ile_de_france)).
fof(sda_auvergne_rhone_alpes_disjoint_nouvelle_aquitaine, axiom, kge_disjoint(gn_auvergne_rhone_alpes, gn_nouvelle_aquitaine)).
fof(sda_auvergne_rhone_alpes_disjoint_occitanie, axiom, kge_disjoint(gn_auvergne_rhone_alpes, gn_occitanie)).
fof(sda_auvergne_rhone_alpes_disjoint_provence_alpes_cote_d_azur, axiom, kge_disjoint(gn_auvergne_rhone_alpes, gn_provence_alpes_cote_d_azur)).
fof(sda_grand_est_disjoint_ile_de_france, axiom, kge_disjoint(gn_grand_est, gn_ile_de_france)).
fof(sda_grand_est_disjoint_nouvelle_aquitaine, axiom, kge_disjoint(gn_grand_est, gn_nouvelle_aquitaine)).
fof(sda_grand_est_disjoint_occitanie, axiom, kge_disjoint(gn_grand_est, gn_occitanie)).
fof(sda_grand_est_disjoint_provence_alpes_cote_d_azur, axiom, kge_disjoint(gn_grand_est, gn_provence_alpes_cote_d_azur)).
fof(sda_ile_de_france_disjoint_nouvelle_aquitaine, axiom, kge_disjoint(gn_ile_de_france, gn_nouvelle_aquitaine)).
fof(sda_ile_de_france_disjoint_occitanie, axiom, kge_disjoint(gn_ile_de_france, gn_occitanie)).
fof(sda_ile_de_france_disjoint_provence_alpes_cote_d_azur, axiom, kge_disjoint(gn_ile_de_france, gn_provence_alpes_cote_d_azur)).
fof(sda_nouvelle_aquitaine_disjoint_occitanie, axiom, kge_disjoint(gn_nouvelle_aquitaine, gn_occitanie)).
fof(sda_nouvelle_aquitaine_disjoint_provence_alpes_cote_d_azur, axiom, kge_disjoint(gn_nouvelle_aquitaine, gn_provence_alpes_cote_d_azur)).
fof(sda_occitanie_disjoint_provence_alpes_cote_d_azur, axiom, kge_disjoint(gn_occitanie, gn_provence_alpes_cote_d_azur)).

% ----- Siblings under gn_germany (featureCode A.ADM1) -----
fof(sda_baden_wuerttemberg_disjoint_bayern, axiom, kge_disjoint(gn_baden_wuerttemberg, gn_bayern)).
fof(sda_baden_wuerttemberg_disjoint_berlin, axiom, kge_disjoint(gn_baden_wuerttemberg, gn_berlin)).
fof(sda_bayern_disjoint_berlin, axiom, kge_disjoint(gn_bayern, gn_berlin)).
