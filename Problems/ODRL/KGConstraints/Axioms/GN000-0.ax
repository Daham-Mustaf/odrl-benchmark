%--------------------------------------------------------------------------
% File     : GN000-0.ax
% Domain   : ODRL Policy / KB Grounding Concept-valued
% Axioms   : GeoNames slice for the spatial operand
% Version  : 1.1
% English  : Concrete grounding facts for the spatial left operand,
%           : derived from a 15-feature slice of GeoNames covering
%           : the EU example region with 14 direct gn:parentFeature
%           : edges.  Disjointness is NOT asserted: GeoNames does not
%           : assert sibling disjointness, so the base resource yields
%           : Compatible or Unknown verdicts for spatial constraints.
%           : Conflict verdicts require the SDA (Sibling Disjointness
%           : Assumption) profile, applied separately.
%
% Refs     : [Mus+26] Mustafa, D., Chollarana, D., Haque, R., Peng, Y., Quix, C., Lange, C., Geisler, S., Decker, S. Conflict Detection via Denotational Semantics: Policy Reasoning over Incomplete Hierarchies. arXiv:2602.19883. https://arxiv.org/abs/2602.19883
% Source   : Mustafa, D. (2026)
% Authors  : Mustafa, D. & Sutcliffe, G.
% Names    : GN000-0.ax
%
% Status   : Satisfiable
% SPC      : FOF_SAT_RFN
%
% Comments : Generated from Resources/geonames.ttl by gen_geonames.py.
%           : Depends on KGE000-0.ax (kge_leq signature, kge_leq_transitive,
%           : kge_leq_antisymmetric, kge_leq_reflexive).
%           : 14 direct gn:parentFeature edges over 15 features.
%           : Acyclicity is verified at generation time.
%           : NO disjointness asserted (OWA).  Problem files emit:
%           : include('Axioms/KGE000-0.ax').
%           : include('Axioms/DENOT000-0.ax').
%           : include('Axioms/GN000-0.ax').
%           : No axiom file self-includes this file.
%           : 14 axioms: 14 direct gn:parentFeature edges (transitive closure via KGE000-0.ax).
%--------------------------------------------------------------------------

% ==========================================================================
% GeoNames slice                            [Paper: tab:realizations,
%                                             Example 1 spatial pair]
%
% Source: Resources/geonames.ttl
% Encoding: each gn:Feature is a TPTP constant named from gn:name;
% the numeric GeoNames ID is preserved as a comment for traceability
% to the live sws.geonames.org IRIs.  gn:parentFeature edges are
% emitted as direct kge_leq facts; transitive closure is provided
% by KGE000-0.ax::kge_leq_transitive at proof time.
%
% Note on relation choice: the paper's Table 1 names gn:sfWithin as
% the spatial-containment relation.  We operationalize this for
% administrative units via gn:parentFeature, the relation GeoNames
% uses for political/administrative hierarchy.  gn:sfWithin would
% require GeoSPARQL geometries that GeoNames RDF does not
% consistently provide.
%
% gn:parentCountry and gn:parentADM1 shortcut edges are NOT emitted.
% Soundness assumes the gn:parentFeature chain is complete from each
% feature up to the resource root; verified at generation time only
% to the extent that all referenced features are typed gn:Feature.
%
% Cross-resource convention: this file asserts only GeoNames facts.
%
% NO disjointness facts are asserted.  GeoNames does not assert
% sibling disjointness, and that absence yields Unknown verdicts
% on spatial pairs without a shared descendant.  Conflict verdicts
% on the spatial operand require the SDA (Sibling Disjointness
% Assumption) profile, applied at evaluation time.
%
% Features: 15.  Direct gn:parentFeature edges: 14.
% Acyclicity verified at generation time.
% ==========================================================================
% Features in this fragment (numeric IDs from sws.geonames.org):
%   gn_auvergne_rhone_alpes          = 11071625  [A.ADM1]  (Auvergne-Rhone-Alpes)
%   gn_baden_wuerttemberg            = 2953481  [A.ADM1]  (Baden-Wuerttemberg)
%   gn_bayern                        = 2951839  [A.ADM1]  (Bayern)
%   gn_berlin                        = 2950157  [A.ADM1]  (Berlin)
%   gn_europe                        = 6255148  [L.CONT]  (Europe)
%   gn_france                        = 3017382  [A.PCLI]  (France)
%   gn_germany                       = 2921044  [A.PCLI]  (Germany)
%   gn_grand_est                     = 11071622  [A.ADM1]  (Grand Est)
%   gn_ile_de_france                 = 3012874  [A.ADM1]  (Ile-de-France)
%   gn_munich                        = 2867714  [P.PPLA]  (Munich)
%   gn_nouvelle_aquitaine            = 11071620  [A.ADM1]  (Nouvelle-Aquitaine)
%   gn_occitanie                     = 11071623  [A.ADM1]  (Occitanie)
%   gn_paris                         = 2988507  [P.PPLC]  (Paris)
%   gn_provence_alpes_cote_d_azur    = 2985244  [A.ADM1]  (Provence-Alpes-Cote d'Azur)
%   gn_strasbourg                    = 2973783  [P.PPLA]  (Strasbourg)

% gn:parentFeature edges (transitive closure via KGE000-0.ax)
% Auvergne-Rhone-Alpes (11071625) parentFeature France (3017382)
fof(gn_auvergne_rhone_alpes_leq_france, axiom, kge_leq(gn_auvergne_rhone_alpes, gn_france)).
% Baden-Wuerttemberg (2953481) parentFeature Germany (2921044)
fof(gn_baden_wuerttemberg_leq_germany, axiom, kge_leq(gn_baden_wuerttemberg, gn_germany)).
% Bayern (2951839) parentFeature Germany (2921044)
fof(gn_bayern_leq_germany, axiom, kge_leq(gn_bayern, gn_germany)).
% Berlin (2950157) parentFeature Germany (2921044)
fof(gn_berlin_leq_germany, axiom, kge_leq(gn_berlin, gn_germany)).
% France (3017382) parentFeature Europe (6255148)
fof(gn_france_leq_europe, axiom, kge_leq(gn_france, gn_europe)).
% Germany (2921044) parentFeature Europe (6255148)
fof(gn_germany_leq_europe, axiom, kge_leq(gn_germany, gn_europe)).
% Grand Est (11071622) parentFeature France (3017382)
fof(gn_grand_est_leq_france, axiom, kge_leq(gn_grand_est, gn_france)).
% Ile-de-France (3012874) parentFeature France (3017382)
fof(gn_ile_de_france_leq_france, axiom, kge_leq(gn_ile_de_france, gn_france)).
% Munich (2867714) parentFeature Bayern (2951839)
fof(gn_munich_leq_bayern, axiom, kge_leq(gn_munich, gn_bayern)).
% Nouvelle-Aquitaine (11071620) parentFeature France (3017382)
fof(gn_nouvelle_aquitaine_leq_france, axiom, kge_leq(gn_nouvelle_aquitaine, gn_france)).
% Occitanie (11071623) parentFeature France (3017382)
fof(gn_occitanie_leq_france, axiom, kge_leq(gn_occitanie, gn_france)).
% Paris (2988507) parentFeature Ile-de-France (3012874)
fof(gn_paris_leq_ile_de_france, axiom, kge_leq(gn_paris, gn_ile_de_france)).
% Provence-Alpes-Cote d'Azur (2985244) parentFeature France (3017382)
fof(gn_provence_alpes_cote_d_azur_leq_france, axiom, kge_leq(gn_provence_alpes_cote_d_azur, gn_france)).
% Strasbourg (2973783) parentFeature Grand Est (11071622)
fof(gn_strasbourg_leq_grand_est, axiom, kge_leq(gn_strasbourg, gn_grand_est)).
