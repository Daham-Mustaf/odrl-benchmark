%--------------------------------------------------------------------------
% File     : DPV003-0.ax : TPTP v0.1.0
% Domain   : Data Privacy Vocabulary (W3C DPV v2.2)
% Axioms   : DPV Unique Name Assumption — cross-level distinctness
% Source   : Extension benchmarks (Mustafa & Sutcliffe, 2026)
% Scope    : Every leaf concept ≠ every inner node (6 leaves × 5 nodes)
% Depends  : DPV000-0.ax, DPV002-0.ax
% Note     : Required when neq or isNoneOf needs a witness that is
%            a child but distinct from its parent. Without these,
%            the prover can collapse child = parent.
%            Discovered via ODRL151-1 failure analysis.
% Status   : Layer 0 — NOT YET FROZEN
% Authors  : Mustafa, D. & Sutcliffe, G.
%--------------------------------------------------------------------------

% --- academicResearch ≠ all inner nodes ---
fof(dpv_xl_acad_top,     axiom, academicResearch != purpose).
fof(dpv_xl_acad_comm,    axiom, academicResearch != commercialPurpose).
fof(dpv_xl_acad_noncomm, axiom, academicResearch != nonCommercialPurpose).
fof(dpv_xl_acad_rnd,     axiom, academicResearch != researchAndDevelopment).
fof(dpv_xl_acad_mkt,     axiom, academicResearch != marketing).

% --- scientificResearch ≠ all inner nodes ---
fof(dpv_xl_sci_top,      axiom, scientificResearch != purpose).
fof(dpv_xl_sci_comm,     axiom, scientificResearch != commercialPurpose).
fof(dpv_xl_sci_noncomm,  axiom, scientificResearch != nonCommercialPurpose).
fof(dpv_xl_sci_rnd,      axiom, scientificResearch != researchAndDevelopment).
fof(dpv_xl_sci_mkt,      axiom, scientificResearch != marketing).

