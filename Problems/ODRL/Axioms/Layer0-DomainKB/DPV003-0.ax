fof(dpv_xl_ncr_mkt,      axiom, nonCommercialResearch != marketing).

% --- advertising ≠ all inner nodes ---
fof(dpv_xl_adv_top,      axiom, advertising != purpose).
fof(dpv_xl_adv_comm,     axiom, advertising != commercialPurpose).
fof(dpv_xl_adv_noncomm,  axiom, advertising != nonCommercialPurpose).
fof(dpv_xl_adv_rnd,      axiom, advertising != researchAndDevelopment).
fof(dpv_xl_adv_mkt,      axiom, advertising != marketing).

% --- directMarketing ≠ all inner nodes ---
fof(dpv_xl_dm_top,       axiom, directMarketing != purpose).
fof(dpv_xl_dm_comm,      axiom, directMarketing != commercialPurpose).
