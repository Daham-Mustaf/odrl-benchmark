(* ===== EXAMPLE 1: Purpose conflict ===== *)

(* STEP 1: Two ODRL policies in JSON-LD *)

(* Policy A (permission):
   {
     "@type": "odrl:Permission",
     "odrl:action": "odrl:use",
     "odrl:constraint": {
       "odrl:leftOperand": "odrl:purpose",
       "odrl:operator": "odrl:isA",
       "odrl:rightOperand": "dpv:ServiceProvision"
     }
   }

   Policy B (prohibition):
   {
     "@type": "odrl:Prohibition",
     "odrl:action": "odrl:use",
     "odrl:constraint": {
       "odrl:leftOperand": "odrl:purpose",
       "odrl:operator": "odrl:isA",
       "odrl:rightOperand": "dpv:AcademicResearch"
     }
   }
*)

(* STEP 2: Extract constraints *)
(* c1 = (purpose, isA, dpv:ServiceProvision) *)
(* c2 = (purpose, isA, dpv:AcademicResearch) *)

(* STEP 3: Look up KB *)
(* KB_purpose from DPV:
     dpv:Purpose
       ├── dpv:ServiceProvision
       │     └── dpv:Marketing
       └── dpv:AcademicResearch
             └── dpv:ScientificResearch
*)

(* STEP 4: Ground values *)
(* γ(dpv:ServiceProvision) = ServiceProvision  ✓ *)
(* γ(dpv:AcademicResearch) = AcademicResearch  ✓ *)

(* STEP 5: Compute denotations *)
(* ⟦c1⟧ = {x ∈ C | x ≤ ServiceProvision}     *)
(*       = {ServiceProvision, Marketing}        *)
(* ⟦c2⟧ = {x ∈ C | x ≤ AcademicResearch}     *)
(*       = {AcademicResearch, ScientificResearch} *)

(* STEP 6: Intersect *)
(* ⟦c1⟧ ∩ ⟦c2⟧ = {} → Conflict *)

lemma "{ServiceProvision, Marketing} 
     ∩ {AcademicResearch, ScientificResearch} = {}"
  by simp


(* ===== EXAMPLE 2: Spatial compatible ===== *)

(* Policy C (permission):
   {
     "@type": "odrl:Permission",
     "odrl:action": "odrl:distribute",
     "odrl:constraint": {
       "odrl:leftOperand": "odrl:spatial",
       "odrl:operator": "odrl:isPartOf",
       "odrl:rightOperand": "gn:Europe"
     }
   }

   Policy D (prohibition):
   {
     "@type": "odrl:Prohibition",
     "odrl:action": "odrl:distribute",
     "odrl:constraint": {
       "odrl:leftOperand": "odrl:spatial",
       "odrl:operator": "odrl:isPartOf",
       "odrl:rightOperand": "gn:France"
     }
   }
*)

(* c3 = (spatial, isPartOf, gn:Europe) *)
(* c4 = (spatial, isPartOf, gn:France) *)

(* KB_spatial from GeoNames (mereological ≤ = ⪯):
     gn:Europe
       ├── gn:France
       │     ├── gn:Paris
       │     └── gn:Lyon
       └── gn:Germany
             └── gn:Berlin
*)

(* γ(gn:Europe) = Europe  ✓ *)
(* γ(gn:France) = France  ✓ *)

(* ⟦c3⟧ = {x | x ⪯ Europe} = {Europe, France, Paris, Lyon, Germany, Berlin} *)
(* ⟦c4⟧ = {x | x ⪯ France} = {France, Paris, Lyon}                         *)

(* ⟦c3⟧ ∩ ⟦c4⟧ = {France, Paris, Lyon} ≠ {} → Compatible *)

lemma "{Europe, France, Paris, Lyon, Germany, Berlin} 
     ∩ {France, Paris, Lyon} ≠ {}"
  by simp


