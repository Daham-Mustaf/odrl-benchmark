(* ===== EXAMPLE 5: Unknown — ungrounded value ===== *)

(* Policy I:
   {
     "odrl:constraint": {
       "odrl:leftOperand": "odrl:purpose",
       "odrl:operator": "odrl:isA",
       "odrl:rightOperand": "ex:MyCustomPurpose"
     }
   }
*)

(* c9 = (purpose, isA, ex:MyCustomPurpose) *)
(* γ(ex:MyCustomPurpose) = ⊥  — not in DPV, unknown concept *)
(* ⟦c9⟧ = ⊤ *)

(* Any constraint vs ⊤ → Unknown *)
(* We need the datatype to show this: *)

datatype D = Classical "string set" | Top
datatype V = Conflict | Compatible | Unknown

fun verdict :: "D ⇒ D ⇒ V" where
  "verdict (Classical s1) (Classical s2) =
     (if s1 ∩ s2 = {} then Conflict else Compatible)"
| "verdict _ _ = Unknown"

(* c1 vs c9: grounded vs ungrounded → Unknown *)
lemma "verdict (Classical {''ServiceProvision'', ''Marketing''}) Top = Unknown"
  by simp

(* c1 vs c2: both grounded, no overlap → Conflict *)
lemma "verdict (Classical {''ServiceProvision'', ''Marketing''}) 
              (Classical {''AcademicResearch'', ''ScientificResearch''}) = Conflict"
  by simp

(* c3 vs c4: both grounded, overlap → Compatible *)
lemma "verdict (Classical {''France'', ''Paris'', ''Lyon''}) 
              (Classical {''Europe'', ''France'', ''Paris'', ''Lyon'', ''Germany'', ''Berlin''}) 
       = Compatible"
  by simp

end
