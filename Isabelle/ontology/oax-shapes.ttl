@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix oax:   <http://w3id.org/odrl/spatial-axis#> .
@prefix odrl:  <http://www.w3.org/ns/odrl/2/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# =============================================================
# Shape: Axis-specific LeftOperands must use xsd:decimal
# =============================================================

oax:AxisConstraintShape
    a sh:NodeShape ;
    sh:targetObjectsOf odrl:leftOperand ;
    sh:message "Axis-specific LeftOperand constraint must use xsd:decimal rightOperand." .

# =============================================================
# Shape: absoluteSizeWidth domain (0, ∞)
# =============================================================

oax:AbsoluteSizeWidthShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:absoluteSizeWidth ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0 ;
        sh:message "absoluteSizeWidth must be > 0."
    ] .

# =============================================================
# Shape: absoluteSizeHeight domain (0, ∞)
# =============================================================

oax:AbsoluteSizeHeightShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:absoluteSizeHeight ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0 ;
        sh:message "absoluteSizeHeight must be > 0."
    ] .

# =============================================================
# Shape: spatialCoordinatesLatitude domain [-90, 90]
# =============================================================

oax:LatitudeShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:spatialCoordinatesLatitude ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minInclusive -90 ;
        sh:maxInclusive 90 ;
        sh:message "Latitude must be in [-90, 90]."
    ] .

# =============================================================
# Shape: spatialCoordinatesLongitude domain [-180, 180]
# =============================================================

oax:LongitudeShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:spatialCoordinatesLongitude ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minInclusive -180 ;
        sh:maxInclusive 180 ;
        sh:message "Longitude must be in [-180, 180]."
    ] .

# =============================================================
# Shape: relativeSpatialPosition axes domain [0, 100]
# =============================================================

oax:RelativePositionXShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:relativeSpatialPositionX ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:message "relativeSpatialPositionX must be in [0, 100]."
    ] .

oax:RelativePositionYShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this WHERE {
                ?this odrl:leftOperand oax:relativeSpatialPositionY ;
                      odrl:rightOperand ?val .
            }
        """
    ] ;
    sh:property [
        sh:path odrl:rightOperand ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:message "relativeSpatialPositionY must be in [0, 100]."
    ] .
